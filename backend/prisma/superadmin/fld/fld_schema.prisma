model Sector {
  sectorId            Int                  @id @default(autoincrement()) @map("sector_id")
  sectorName          String               @unique @map("sector_name")
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther             Boolean              @default(false) @map("is_other")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  categories          FldCategory[]
  kvkFldIntroductions KvkFldIntroduction[]
  subCategories       FldSubcategory[]
  thematicAreas       FldThematicArea[]

  @@index([sectorId])
  @@index([sectorName])
  @@map("sector")
}

model FldThematicArea {
  thematicAreaId      Int                  @id @default(autoincrement()) @map("thematic_area_id")
  thematicAreaName    String               @map("thematic_area_name")
  sectorId            Int
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther             Boolean              @default(false) @map("is_other")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  kvkFldIntroductions KvkFldIntroduction[]
  sector              Sector               @relation(fields: [sectorId], references: [sectorId], onDelete: Cascade)

  @@index([sectorId])
  @@index([thematicAreaName])
  @@map("thematic_area")
}

model FldCategory {
  categoryId          Int                  @id @default(autoincrement()) @map("category_id")
  categoryName        String               @map("category_name")
  sectorId            Int
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther             Boolean              @default(false) @map("is_other")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  sector              Sector               @relation(fields: [sectorId], references: [sectorId], onDelete: Cascade)
  crops               FldCrop[]
  kvkFldIntroductions KvkFldIntroduction[]
  subCategories       FldSubcategory[]

  @@index([sectorId])
  @@index([categoryName])
  @@map("category")
}

model FldSubcategory {
  subCategoryId       Int                  @id @default(autoincrement()) @map("sub_category_id")
  subCategoryName     String               @map("sub_category_name")
  categoryId          Int
  sectorId            Int
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther             Boolean              @default(false) @map("is_other")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  crops               FldCrop[]
  kvkFldIntroductions KvkFldIntroduction[]
  category            FldCategory          @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)
  sector              Sector               @relation(fields: [sectorId], references: [sectorId], onDelete: Cascade)

  @@index([subCategoryId])
  @@index([categoryId])
  @@index([sectorId])
  @@index([subCategoryName])
  @@map("sub_category")
}

model FldCrop {
  cropId                Int                    @id @default(autoincrement()) @map("crop_id")
  cropName              String                 @map("crop_name")
  categoryId            Int
  subCategoryId         Int
  // Default unit + quantity data type for this crop. Downstream FLD forms show
  // the unit read-only and constrain the quantity input to this type.
  unitId                Int?                   @map("unit_id")
  // 'number' | 'decimal' | 'string' | 'boolean'
  quantityDataType      String?                @map("quantity_data_type")
  quantityRequired      Boolean                @default(false) @map("quantity_required")
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther               Boolean                @default(false) @map("is_other")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  category              FldCategory            @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)
  subCategory           FldSubcategory         @relation(fields: [subCategoryId], references: [subCategoryId], onDelete: Cascade)
  unit                  Unit?                  @relation(fields: [unitId], references: [unitId], onDelete: SetNull)
  fldTechnicalFeedbacks FldTechnicalFeedback[]
  kvkBudgetUtilizations KvkBudgetUtilization[]
  kvkFldIntroductions   KvkFldIntroduction[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([cropName])
  @@index([unitId])
  @@map("crop")
}
