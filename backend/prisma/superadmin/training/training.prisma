model TrainingType {
  trainingTypeId   Int                   @id @default(autoincrement()) @map("training_type_id")
  trainingTypeName String                @unique @map("training_type_name")
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther          Boolean               @default(false) @map("is_other")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  trainingAreas    TrainingArea[]
  trainingAchievements TrainingAchievement[]

  @@index([trainingTypeId])
  @@index([trainingTypeName])
  @@map("training_type")
}

model TrainingArea {
  trainingAreaId   Int                    @id @default(autoincrement()) @map("training_area_id")
  trainingAreaName String                 @map("training_area_name")
  trainingTypeId   Int?
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther          Boolean                @default(false) @map("is_other")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  trainingType     TrainingType?          @relation(fields: [trainingTypeId], references: [trainingTypeId], onDelete: SetNull)
  thematicAreas    TrainingThematicArea[]
  trainingAchievements TrainingAchievement[]

  @@index([trainingAreaId])
  @@index([trainingTypeId])
  @@index([trainingAreaName])
  @@map("training_area")
}

model TrainingThematicArea {
  trainingThematicAreaId   Int                   @id @default(autoincrement()) @map("training_thematic_area_id")
  trainingThematicAreaName String                @map("training_thematic_area_name")
  trainingAreaId           Int?
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther                  Boolean               @default(false) @map("is_other")
  createdAt                DateTime              @default(now()) @map("created_at")
  updatedAt                DateTime              @updatedAt @map("updated_at")
  trainingArea             TrainingArea?         @relation(fields: [trainingAreaId], references: [trainingAreaId], onDelete: SetNull)
  trainingAchievements     TrainingAchievement[]

  @@index([trainingThematicAreaId])
  @@index([trainingAreaId])
  @@index([trainingThematicAreaName])
  @@map("training_thematic_area")
}
