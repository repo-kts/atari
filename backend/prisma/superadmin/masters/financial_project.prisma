model FinancialProject {
  financialProjectId Int              @id @default(autoincrement()) @map("financial_project_id")
  projectName        String           @unique @map("project_name")
  isOther            Boolean          @default(false) @map("is_other")
  fundingSourceId    Int?             @map("funding_source_id")
  fundingSource      FundingSourceMaster? @relation(fields: [fundingSourceId], references: [fundingSourceId], onDelete: SetNull)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  projectBudgets     ProjectBudget[]

  @@index([financialProjectId])
  @@index([projectName])
  @@index([fundingSourceId])
  @@map("financial_project")
}
