model TrainingTypeMaster {
  trainingTypeId Int    @id @default(autoincrement()) @map("training_type_id")
  name           String @unique @map("name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trainings TrainingAchievement[]

  @@map("training_type_master")
}
