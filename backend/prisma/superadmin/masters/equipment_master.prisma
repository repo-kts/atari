model EquipmentMaster {
  equipmentMasterId Int      @id @default(autoincrement()) @map("equipment_master_id")
  equipmentTypeId   Int      @map("equipment_type_id")
  name              String   @map("name")
  isOther           Boolean  @default(false) @map("is_other")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  equipmentType EquipmentTypeMaster @relation(fields: [equipmentTypeId], references: [equipmentTypeId], onDelete: Cascade)
  equipments    KvkEquipment[]
  // Migration-only reverse-lookup rows (old-site raw names). See EquipmentModelMaster.
  equipmentModels EquipmentModelMaster[]

  @@unique([equipmentTypeId, name])
  @@index([equipmentTypeId])
  @@map("equipment_master")
}
