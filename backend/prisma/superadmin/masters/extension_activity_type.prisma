model FldActivity {
  activityId              Int                     @id @default(autoincrement()) @map("activity_id")
  activityName            String                  @unique @map("activity_name")
  isOther                 Boolean                 @default(false) @map("is_other")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  extensions              FldExtension[]
  
  kvkExtensionActivities  KvkExtensionActivity[]
  craExtensionActivities  CraExtensionActivity[]

  @@map("fld_activity") 
}
