model TrainingAreaMaster {
  trainingAreaId Int    @id @default(autoincrement()) @map("training_area_id")
  name           String @unique @map("name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trainings TrainingAchievement[]

  @@map("training_area_master")
}
