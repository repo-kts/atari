model EquipmentTypeMaster {
  equipmentTypeId Int      @id @default(autoincrement()) @map("equipment_type_id")
  name            String   @unique @map("name")
  isOther         Boolean  @default(false) @map("is_other")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  equipments  KvkEquipment[]
  equipmentMasters EquipmentMaster[]

  @@map("equipment_type_master")
}
