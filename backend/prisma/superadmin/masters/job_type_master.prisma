model JobTypeMaster {
  jobTypeId Int        @id @default(autoincrement()) @map("job_type_id")
  name      String     @unique @map("name")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  staff     KvkStaff[]

  @@map("job_type_master")
}
