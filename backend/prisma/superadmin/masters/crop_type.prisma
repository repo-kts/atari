model CropType {
  typeId    Int             @id @default(autoincrement()) @map("type_id")
  typeName  String          @unique @map("type_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cfldCrops FLDCropMaster[] 

  @@index([typeId])
  @@index([typeName])
  @@map("crop_type")
}
