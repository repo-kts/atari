model StaffCategoryMaster {
  staffCategoryId Int        @id @default(autoincrement()) @map("staff_category_id")
  categoryName    String     @unique @map("category_name")
  isOther         Boolean    @default(false) @map("is_other")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  staff           KvkStaff[]
  demonstrationInfo DemonstrationInfo[]

  @@map("staff_category_master")
}
