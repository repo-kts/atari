model Discipline {
  disciplineId   Int        @id @default(autoincrement()) @map("discipline_id")
  disciplineName String     @unique @map("discipline_name")
  // Flags this row as the "Other" option (form then shows a specify input).
  isOther        Boolean    @default(false) @map("is_other")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  kvkOfts        Kvkoft[]
  staff          KvkStaff[]

  @@map("discipline")
}
