model Discipline {
  disciplineId   Int        @id @default(autoincrement()) @map("discipline_id")
  disciplineName String     @unique @map("discipline_name")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  kvkOfts        Kvkoft[]
  staff          KvkStaff[]

  @@map("discipline")
}
