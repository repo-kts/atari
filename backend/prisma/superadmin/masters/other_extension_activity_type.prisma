
model OtherExtensionActivityType {
  activityTypeId Int    @id @default(autoincrement()) @map("activity_type_id")
  activityName   String @unique @map("activity_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  otherExtensionActivities KvkOtherExtensionActivity[]
  
  @@map("other_extension_activity_type")
}
