model AssetFundingSourceMaster {
  assetFundingSourceId Int      @id @default(autoincrement()) @map("asset_funding_source_id")
  name                 String   @unique @map("name")
  isOther              Boolean  @default(false) @map("is_other")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  equipments        KvkEquipment[]
  equipmentDetails  KvkEquipmentDetail[]
  vehicleDetails    KvkVehicleDetail[]

  @@map("asset_funding_source_master")
}
