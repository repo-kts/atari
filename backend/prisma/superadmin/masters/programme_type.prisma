model ProgrammeTypeMaster {
  programmeTypeId Int      @id @default(autoincrement()) @map("programme_type_id")
  programmeType   String   @unique @map("programme_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("programme_type_master")
}
