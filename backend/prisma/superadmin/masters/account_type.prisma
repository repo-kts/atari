model AccountTypeMaster {
  accountTypeId Int              @id @default(autoincrement()) @map("account_type_id")
  accountType   String           @map("account_type")
  // Flags this row as the "Other" option (forms then show a specify input).
  isOther       Boolean          @default(false) @map("is_other")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  bankAccounts  KvkBankAccount[]

  @@map("account_type_master")
}
