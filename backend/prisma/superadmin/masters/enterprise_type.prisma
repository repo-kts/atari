model EnterpriseTypeMaster {
  enterpriseTypeId   Int                @id @default(autoincrement()) @map("enterprise_type_id")
  enterpriseTypeName String             @unique @map("enterprise_type_name")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([enterpriseTypeId])
  @@index([enterpriseTypeName])
  @@map("enterprise_type_master")
}
