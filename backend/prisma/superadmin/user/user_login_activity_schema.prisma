model UserLoginActivity {
  logId       Int      @id @default(autoincrement()) @map("log_id")
  userId      Int?     @map("user_id")
  kvkId       Int?     @map("kvk_id")
  userName    String?  @map("user_name")
  userEmail   String?  @map("user_email")
  roleName    String?  @map("role_name")
  zoneId      Int?     @map("zone_id")
  stateId     Int?     @map("state_id")
  districtId  Int?     @map("district_id")
  orgId       Int?     @map("org_id")
  kvkName     String?  @map("kvk_name")
  activity    String
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  eventAt     DateTime @default(now()) @map("event_at")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [userId], onDelete: SetNull)
  kvk         Kvk?     @relation(fields: [kvkId], references: [kvkId], onDelete: SetNull)

  @@index([eventAt])
  @@index([kvkId, eventAt])
  @@index([userId, eventAt])
  @@index([activity, eventAt])
  @@index([zoneId, eventAt])
  @@index([stateId, eventAt])
  @@index([districtId, eventAt])
  @@index([orgId, eventAt])
  @@map("user_login_activity")
}
