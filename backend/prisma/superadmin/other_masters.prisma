model YearMaster {
  yearId                            Int                          @id @default(autoincrement()) @map("year_id")
  yearName                          String                       @unique @map("year_name")
  createdAt                         DateTime                     @default(now()) @map("created_at")
  updatedAt                         DateTime                     @updatedAt @map("updated_at")
  aryaCurrentYearRecords            AryaCurrentYear[]
  aryaPrevYearRecords               AryaPrevYear[]
  atariMeetingRecords               AtariMeeting[]
  csisaRecords                      Csisa[]
  drmrActivityRecords               DrmrActivity[]
  drmrDetailsRecords                DrmrDetails[]
  fldExtensionRecords               FldExtension[]
  fldTechnicalFeedbackRecords       FldTechnicalFeedback[]
  fpoCbboRecords                    FpoCbboDetails[]
  fpoManagementRecords              FpoManagement[]
  geographicalInfoRecords           GeographicalInfo[]
  agriDroneRecords                  KvkAgriDrone[]
  kvkEquipmentRecords               KvkEquipment[]
  kvkOftRecords                     Kvkoft[]
  productionSupplyRecords           KvkProductionSupply[]
  publicationDetailsRecords         KvkPublicationDetails[]
  kvkAwardRecords                   KvkAward[]
  scientistAwardRecords             ScientistAward[]
  farmerAwardRecords                FarmerAward[]
  seedHubRecords                    KvkSeedHubProgram[]
  soilWaterAnalysisRecords          KkvSoilWaterAnalysis[]
  soilWaterEquipmentRecords         KkvSoilWaterEquipment[]
  kvkVehicleRecords                 KvkVehicle[]
  worldSoilCelebrationRecords       KkvWorldSoilCelebration[]
  nicraDetailsRecords               NicraDetails[]
  swachhQuarterlyExpenditureRecords SwachhQuarterlyExpenditure[]

  // Performance Indicators (from main/incoming change)
  kvkImpactActivityRecords          KvkImpactActivity[]
  entrepreneurshipRecords           Entrepreneurship[]
  successStoryRecords               SuccessStory[]
  districtLevelDataRecords          DistrictLevelData[]
  operationalAreaRecords            OperationalArea[]
  villageAdoptionRecords            VillageAdoption[]
  priorityThrustAreaRecords          PriorityThrustArea[]
  demonstrationUnitRecords          DemonstrationUnit[]
  instructionalFarmCropRecords      InstructionalFarmCrop[]
  productionUnitRecords             ProductionUnit[]
  instructionalFarmLivestockRecords InstructionalFarmLivestock[]
  hostelUtilizationRecords          HostelUtilization[]
  rainwaterHarvestingRecords        RainwaterHarvesting[]
  revolvingFundRecords              RevolvingFund[]
  functionalLinkageRecords          FunctionalLinkage[]
  specialProgrammeRecords           SpecialProgramme[]
  topCrop                           TopCrop[]
  nariNutriGardenRecords            NariNutriGarden[]
  nariBioFortifiedCropRecords       NariBioFortifiedCrop[]
  nariValueAdditionRecords          NariValueAddition[]
  nariTrainingProgramRecords        NariTrainingProgram[]
  nariExtensionActivityRecords      NariExtensionActivity[]
  nicraRevenueGeneratedRecords       NicraRevenueGenerated[]
  nicraFarmImplementRecords         NicraFarmImplement[]
  nicraVcrmcRecords                 NicraVcrmc[]
  craDetailsRecords                 CraDetails[]

  @@index([yearId])
  @@index([yearName])
  @@map("year_master")
}
