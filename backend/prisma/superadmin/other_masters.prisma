model YearMaster {
  yearId   Int    @id @default(autoincrement()) @map("year_id")
  yearName String @unique @map("year_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([yearId])
  @@index([yearName])
  @@map("year_master")
}
