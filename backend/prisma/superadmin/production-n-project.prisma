model ProductCategory {
  productCategoryId   Int           @id @default(autoincrement()) @map("product_category_id")
  productCategoryName String        @unique @map("product_category_name")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  products            Product[]
  productTypes        ProductType[]
  productionSupplies  KvkProductionSupply[]

  @@index([productCategoryId])
  @@index([productCategoryName])
  @@map("product_category")
}

model ProductType {
  productTypeId       Int              @id @default(autoincrement()) @map("product_type_id")
  productCategoryType String           @map("product_category_type")
  productCategoryId   Int?             @map("product_category_id")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  products            Product[]
  productCategory     ProductCategory?        @relation(fields: [productCategoryId], references: [productCategoryId], onDelete: Cascade)
  productionSupplies  KvkProductionSupply[]

  @@index([productTypeId])
  @@index([productCategoryType])
  @@index([productCategoryId])
  @@map("product_type")
}

model Product {
  productId         Int                    @id @default(autoincrement()) @map("product_id")
  productName       String                 @map("product_name")
  productCategoryId Int?                   @map("product_category_id")
  productTypeId     Int?                   @map("product_type_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  productCategory   ProductCategory?        @relation(fields: [productCategoryId], references: [productCategoryId], onDelete: Cascade)
  productType       ProductType?            @relation(fields: [productTypeId], references: [productTypeId], onDelete: Cascade)
  productionSupplies KvkProductionSupply[]

  @@index([productId])
  @@index([productName])
  @@index([productTypeId])
  @@index([productCategoryId])
  @@map("product")
}

model CraCropingSystem {
  craCropingSystemId Int      @id @default(autoincrement()) @map("cra_croping_system_id")
  cropName           String   @map("crop_name")
  seasonId           Int      @map("season_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  season             Season   @relation(fields: [seasonId], references: [seasonId], onDelete: Cascade)

  @@index([craCropingSystemId])
  @@index([cropName])
  @@index([seasonId])
  @@map("cra_croping_system")
}

model CraFarmingSystem {
  craFarmingSystemId Int      @id @default(autoincrement()) @map("cra_farming_system_id")
  farmingSystemName  String   @map("farming_system_name")
  seasonId           Int      @map("season_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  season             Season   @relation(fields: [seasonId], references: [seasonId], onDelete: Cascade)

  @@index([craFarmingSystemId])
  @@index([farmingSystemName])
  @@index([seasonId])
  @@map("cra_farming_system")
}

model AryaEnterprise {
  aryaEnterpriseId Int      @id @default(autoincrement()) @map("arya_enterprise_id")
  enterpriseName   String   @unique @map("enterprise_name")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([aryaEnterpriseId])
  @@index([enterpriseName])
  @@map("arya_enterprise")
}
