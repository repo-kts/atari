model KvkBankAccount {
  bankAccountId Int         @id @default(autoincrement()) @map("bank_account_id")
  kvkId         Int
  accountType   AccountType @map("account_type")
  // Optional master-backed account type (kept alongside the enum for back-compat).
  accountTypeMasterId Int?  @map("account_type_master_id")
  // Free-text value when the selected account type is the "Other" option (#237).
  accountTypeOther    String? @map("account_type_other")
  accountName   String      @map("account_name")
  bankName      String      @map("bank_name")
  location      String      @map("location")
  accountNumber String      @map("account_number")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  kvk           Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  accountTypeMaster AccountTypeMaster? @relation(fields: [accountTypeMasterId], references: [accountTypeId], onDelete: SetNull)

  @@index([kvkId])
  @@index([accountTypeMasterId])
  @@map("kvk_bank_account")
}

enum AccountType {
  KVK
  REVOLVING_FUND
  OTHER
}
