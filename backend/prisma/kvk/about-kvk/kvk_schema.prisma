model Kvk {
  kvkId                         Int                            @id @default(autoincrement()) @map("kvk_id")
  kvkName                       String                         @map("kvk_name")
  zoneId                        Int
  stateId                       Int
  districtId                    Int
  orgId                         Int                            @map("org_id")
  universityId                  Int?                           @map("university_id")
  hostOrg                       String                         @map("host_org_name")
  mobile                        String                         @map("mobile")
  email                         String                         @map("email")
  address                       String                         @map("address")
  yearOfSanction                Int                            @map("year_of_sanction")
  createdAt                     DateTime                       @default(now()) @map("created_at")
  updatedAt                     DateTime                       @updatedAt @map("updated_at")
  aryaCurrentYear               AryaCurrentYear[]
  aryaPrevYear                  AryaPrevYear[]
  atariMeeting                  AtariMeeting[]
  beneficiariesDetails          BeneficiariesDetails[]
  cfldTechnicalParameters       CfldTechnicalParameter[]
  csisa                         Csisa[]
  demonstrationInfo             DemonstrationInfo[]
  drmrActivity                  DrmrActivity[]
  drmrDetails                   DrmrDetails[]
  extensionActivityOrganized    ExtensionActivityOrganized[]
  farmerAwards                  FarmerAward[]
  financialInformation          FinancialInformation[]
  fldExtensions                 FldExtension[]
  fldTechnicalFeedbacks         FldTechnicalFeedback[]
  fpoCbboDetails                FpoCbboDetails[]
  fpoManagements                FpoManagement[]
  geographicalInfo              GeographicalInfo[]
  hrdPrograms                   HrdProgram[]
  district                      DistrictMaster                 @relation(fields: [districtId], references: [districtId])
  org                           OrgMaster                      @relation(fields: [orgId], references: [orgId])
  state                         StateMaster                    @relation(fields: [stateId], references: [stateId])
  university                    UniversityMaster?              @relation(fields: [universityId], references: [universityId])
  zone                          Zone                           @relation(fields: [zoneId], references: [zoneId])
  agriDrones                    KvkAgriDrone[]
  kvkAwards                     KvkAward[]
  bankAccounts                  KvkBankAccount[]
  kvkBudgetUtilizations         KvkBudgetUtilization[]
  equipments                    KvkEquipment[]
  kvkExtensionActivities        KvkExtensionActivity[]
  farmImplements                KvkFarmImplement[]
  kvkFldIntroductions           KvkFldIntroduction[]
  kvkImportantDayCelebrations   KvkImportantDayCelebration[]
  infrastructures               KvkInfrastructure[]
  kvkOfts                       Kvkoft[]
  kvkOtherExtensionActivities   KvkOtherExtensionActivity[]
  kvkOtherProgrammes            KvkOtherProgramme[]
  productionSupplies            KvkProductionSupply[]
  publicationDetails            KvkPublicationDetails[]
  seedHubPrograms               KvkSeedHubProgram[]
  soilWaterAnalyses             KkvSoilWaterAnalysis[]
  soilWaterEquipments           KkvSoilWaterEquipment[]
  staff                         KvkStaff[]
  originalStaff                 KvkStaff[]                     @relation("OriginalKvk")
  kvkTechnologyWeekCelebrations KvkTechnologyWeekCelebration[]
  vehicles                      KvkVehicle[]
  worldSoilCelebrations         KkvWorldSoilCelebration[]
  nicraBasicInfo                NicraBasicInfo[]
  nicraDetails                  NicraDetails[]
  nicraExtensionActivity        NicraExtensionActivity[]
  nicraTraining                 NicraTraining[]
  physicalInfo                  PhysicalInfo[]
  sacMeeting                    SacMeeting[]
  scientistAwards               ScientistAward[]
  soilDataInformation           SoilDataInformation[]
  transfersFrom                 StaffTransferHistory[]         @relation("TransferFrom")
  transfersTo                   StaffTransferHistory[]         @relation("TransferTo")
  tspScsp                       TspScsp[]
  prevalentDiseasesInCrop       PrevalentDiseasesInCrop[]
  prevalentDiseasesOnLivestock  PrevalentDiseasesOnLivestock[]
  nykTraining                   NykTraining[]
  vipVisitor                    VipVisitor[]
  raweFetFitProgramme           RaweFetFitProgramme[]
  ppvFraTraining                PpvFraTraining[]
  ppvFraPlantVarieties          PpvFraPlantVarieties[]
  swachhQuarterlyExpenditure    SwachhQuarterlyExpenditure[]
  swachhtaHiSewa                SwachhtaHiSewa[]
  swachhtaPakhwada              SwachhtaPakhwada[]
  trainingAchievements          TrainingAchievement[]
  users                         User[]
  moduleImages                  ModuleImage[]
  kvkImpactActivities           KvkImpactActivity[]
  entrepreneurships             Entrepreneurship[]
  successStories                SuccessStory[]
  districtLevelData             DistrictLevelData[]
  operationalAreas              OperationalArea[]
  villageAdoptions              VillageAdoption[]
  priorityThrustAreas           PriorityThrustArea[]
  demonstrationUnits            DemonstrationUnit[]
  instructionalFarmCrops        InstructionalFarmCrop[]
  productionUnits               ProductionUnit[]
  instructionalFarmLivestock    InstructionalFarmLivestock[]
  hostelUtilizations            HostelUtilization[]
  staffQuartersUtilizations     StaffQuartersUtilization[]
  rainwaterHarvestings          RainwaterHarvesting[]
  budgetDetails                 BudgetDetail[]
  projectBudgets                ProjectBudget[]
  revolvingFunds                RevolvingFund[]
  revenueGenerations            RevenueGeneration[]
  resourceGenerations           ResourceGeneration[]
  functionalLinkages            FunctionalLinkage[]
  specialProgrammes             SpecialProgramme[]
  nariNutritionalGarden         NariNutritionalGarden[]
  nariBioFortifiedCrops         NariBioFortifiedCrop[]
  nariValueAdditions            NariValueAddition[]
  nariTrainingProgrammes        NariTrainingProgramme[]
  nariExtensionActivities       NariExtensionActivity[]
  nicraInterventions            NicraIntervention[]
  nicraRevenueGenerateds        NicraRevenueGenerated[]
  nicraFarmImplements           NicraFarmImplement[]
  nicraConvergenceProgrammes    NicraConvergenceProgramme[]
  nicraDignitariesVisiteds      NicraDignitariesVisited[]
  nicraPiCopis                  NicraPiCopi[]
  nicraSoilHealthCards          NicraSoilHealthCard[]
  nicraVcrmcs                   NicraVcrmc[]
  craDetails                    CraDetails[]
  craExtensionActivities        CraExtensionActivity[]
  kmas                          Kmas[]
  mobileApps                    MobileApp[]
  webPortals                    WebPortal[]
  kisanSarathis                 KisanSarathi[]
  msgDetails                    MsgDetails[]
  userLoginActivities           UserLoginActivity[]

  @@index([zoneId])
  @@index([stateId])
  @@index([districtId])
  @@index([orgId])
  @@index([universityId])
  @@index([kvkName])
  @@index([email])
  @@map("kvk")
}
