model KvkVehicle {
  vehicleId       Int                  @id @default(autoincrement()) @map("vehicle_id")
  kvkId           Int
  vehicleName     String               @map("vehicle_name")
  registrationNo  String               @map("registration_no")
  yearOfPurchase  Int                  @map("year_of_purchase")
  totalCost       Float                @map("total_cost")
  totalRun        String               @map("total_run")
  presentStatus   VehiclePresentStatus @map("present_status")
  sourceOfFunding String?              @map("source_of_funding")
  repairingCost   Float?               @map("repairing_cost")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  reportingYearId Int?                 @map("reporting_year_id")
  kvk             Kvk                  @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear   YearMaster?          @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([vehicleName])
  @@index([reportingYearId])
  @@map("kvk_vehicle")
}

enum VehiclePresentStatus {
  WORKING
  GOOD_CONDITION
  NEW
}
