model KvkVehicle {
  vehicleId       Int                  @id @default(autoincrement()) @map("vehicle_id")
  kvkId           Int
  vehicleTypeId   Int?                 @map("vehicle_type_id")
  vehicleTypeOther String?              @map("vehicle_type_other")
  vehicleName     String               @map("vehicle_name")
  registrationNo  String               @map("registration_no")
  yearOfPurchase  Int                  @map("year_of_purchase")
  totalCost       Float                @map("total_cost")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  kvk             Kvk                  @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  vehicleType     VehicleTypeMaster?    @relation(fields: [vehicleTypeId], references: [vehicleTypeId], onDelete: SetNull)
  vehicleDetails  KvkVehicleDetail[]

  @@index([kvkId])
  @@index([vehicleTypeId])
  @@index([vehicleName])
  @@map("kvk_vehicle")
}

model KvkVehicleDetail {
  vehicleDetailId      Int                        @id @default(autoincrement()) @map("vehicle_detail_id")
  kvkId                Int
  vehicleId            Int                        @map("vehicle_id")
  reportingYear        DateTime                   @map("reporting_year")
  totalRun             String                     @map("total_run")
  repairingCost        Float?                     @map("repairing_cost")
  assetFundingSourceId Int?                       @map("asset_funding_source_id")
  assetFundingSourceOther String?                 @map("asset_funding_source_other")
  fundingAgencyName    String?                    @map("funding_agency_name")
  vehicleStatusId      Int                        @map("vehicle_status_id")
  vehicleStatusOther   String?                    @map("vehicle_status_other")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  kvk                  Kvk                        @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  vehicle              KvkVehicle                 @relation(fields: [vehicleId], references: [vehicleId], onDelete: Cascade)
  vehicleStatus        VehiclePresentStatusMaster @relation(fields: [vehicleStatusId], references: [vehicleStatusId])
  assetFundingSource   AssetFundingSourceMaster?  @relation(fields: [assetFundingSourceId], references: [assetFundingSourceId], onDelete: SetNull)

  @@unique([vehicleId, reportingYear])
  @@index([kvkId, reportingYear])
  @@index([vehicleId, reportingYear])
  @@index([vehicleStatusId])
  @@index([assetFundingSourceId])
  @@map("kvk_vehicle_detail")
}
