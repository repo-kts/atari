model KvkEquipment {
  equipmentId          Int                        @id @default(autoincrement()) @map("equipment_id")
  kvkId                Int
  equipmentTypeId      Int?                       @map("equipment_type_id")
  equipmentMasterId    Int?                       @map("equipment_master_id")
  equipmentName        String?                    @map("equipment_name")
  companyBrandModel    String?                    @map("company_brand_model")
  identifierCode       String?                    @map("identifier_code")
  yearOfPurchase       Int                        @map("year_of_purchase")
  totalCost            Float                      @map("total_cost")
  assetFundingSourceId Int?                       @map("asset_funding_source_id")
  createdAt            DateTime                   @default(now()) @map("created_at")
  updatedAt            DateTime                   @updatedAt @map("updated_at")
  kvk                  Kvk                        @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  equipmentType        EquipmentTypeMaster?       @relation(fields: [equipmentTypeId], references: [equipmentTypeId], onDelete: SetNull)
  equipmentMaster      EquipmentMaster?           @relation(fields: [equipmentMasterId], references: [equipmentMasterId], onDelete: SetNull)
  assetFundingSource   AssetFundingSourceMaster?  @relation(fields: [assetFundingSourceId], references: [assetFundingSourceId], onDelete: SetNull)
  equipmentDetails     KvkEquipmentDetail[]

  @@index([kvkId])
  @@index([assetFundingSourceId])
  @@index([equipmentTypeId])
  @@index([equipmentMasterId])
  @@map("kvk_equipment")
}

model KvkEquipmentDetail {
  equipmentDetailId    Int                          @id @default(autoincrement()) @map("equipment_detail_id")
  kvkId                Int
  equipmentId          Int                          @map("equipment_id")
  reportingYear        DateTime                     @map("reporting_year")
  assetFundingSourceId Int?                         @map("asset_funding_source_id")
  equipmentStatusId    Int                          @map("equipment_status_id")
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")
  kvk                  Kvk                          @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  equipment            KvkEquipment                 @relation(fields: [equipmentId], references: [equipmentId], onDelete: Cascade)
  equipmentStatus      EquipmentPresentStatusMaster @relation(fields: [equipmentStatusId], references: [equipmentStatusId])
  assetFundingSource   AssetFundingSourceMaster?    @relation(fields: [assetFundingSourceId], references: [assetFundingSourceId], onDelete: SetNull)

  @@unique([equipmentId, reportingYear])
  @@index([kvkId, reportingYear])
  @@index([equipmentId, reportingYear])
  @@index([equipmentStatusId])
  @@index([assetFundingSourceId])
  @@map("kvk_equipment_detail")
}
