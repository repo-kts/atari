model KvkEquipment {
  equipmentId     Int                    @id @default(autoincrement()) @map("equipment_id")
  kvkId           Int
  equipmentName   String                 @map("equipment_name")
  yearOfPurchase  Int                    @map("year_of_purchase")
  totalCost       Float                  @map("total_cost")
  presentStatus   EquipmentPresentStatus @map("present_status")
  sourceOfFunding String                 @map("source_of_funding")
  type            EquipmentType          @default(EQUIPMENT) @map("type")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  reportingYearId Int?                   @map("reporting_year_id")
  kvk             Kvk                    @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear   YearMaster?            @relation(fields: [reportingYearId], references: [yearId])

  @@index([kvkId])
  @@index([reportingYearId])
  @@map("kvk_equipment")
}

enum EquipmentPresentStatus {
  WORKING
  NOT_WORKING
  CONDEMED
  AUCTION
}

enum EquipmentType {
  EQUIPMENT
  FARM_IMPLEMENT
}
