model HrdProgram {
  hrdProgramId   String   @id @default(uuid()) @map("hrd_program_id")
  kvkId          Int
  kvkStaffId     Int
  courseName     String   @map("course_name")
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  organizerVenue String   @map("organizer_venue")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  kvk            Kvk      @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  staff          KvkStaff @relation(fields: [kvkStaffId], references: [kvkStaffId], onDelete: SetNull)

  @@index([kvkId])
  @@index([kvkStaffId])
  @@index([startDate])
  @@index([createdAt])
  @@map("hrd_program")
}
