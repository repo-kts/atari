model AtariMeeting {
  atariMeetingId          Int         @id @default(autoincrement()) @map("atari_meeting_id")
  kvkId                   Int
  meetingDate             DateTime    @map("meeting_date")
  typeOfMeeting           String      @map("type_of_meeting")
  agenda                  String      @map("agenda")
  representativeFromAtari String      @map("representative_from_atari")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  reportingYearId         Int?        @map("reporting_year_id")
  kvk                     Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear           YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@map("atari_meeting")
}
