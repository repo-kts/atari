model AtariMeeting {
  atariMeetingId          Int         @id @default(autoincrement()) @map("atari_meeting_id")
  kvkId                   Int
  meetingDate             DateTime    @map("meeting_date")
  typeOfMeeting           String      @map("type_of_meeting")
  agenda                  String      @map("agenda")
  representativeFromAtari String      @map("representative_from_atari")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  reportingYear DateTime? @map("reporting_year")
kvk                     Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@map("atari_meeting")
}
