model PrevalentDiseasesInCrop {
  prevalentDiseaseId Int @id @default(autoincrement()) @map("prevalent_disease_id")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId])

  diseaseName            String   @map("disease_name")
  crop                   String
  dateOfOutbreak         DateTime @map("date_of_outbreak")
  areaAffected           Float    @map("area_affected")
  commodityLossPercent   Float    @map("commodity_loss_percent")
  preventiveMeasuresArea Float    @map("preventive_measures_area")

  @@index([kvkId])
  @@map("prevalent_diseases_in_crop")
}
