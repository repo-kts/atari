model PpvFraPlantVarieties {
  ppvFraPlantVarietiesID Int @id @default(autoincrement()) @map("ppv_fra_plant_varieties_id")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  reportingYear Int @map("reporting_year")
  cropName String @map("crop_name")
  farmerName String @map("farmer_name")
  mobile String @map("mobile")
  village   String @map("village")
  block   String @map("block")
  district   String @map("district")
  characteristics String @map("characteristics")
  image String? @map("image")

  @@index([kvkId])
  @@map("ppv_fra_plant_varieties")
}
