model CourseCoordinatorMaster {
  coordinatorId Int                   @id @default(autoincrement()) @map("coordinator_id")
  name          String                @unique @map("name")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  trainings     TrainingAchievement[]

  @@map("course_coordinator_master")
}

model TrainingAchievement {
  trainingAchievementId Int                     @id @default(autoincrement()) @map("training_achievement_id")
  kvkId                 Int
  clienteleId           Int?
  clienteleOther        String?                 @map("clientele_other")
  trainingTypeId        Int?
  trainingTypeOther     String?                 @map("training_type_other")
  trainingAreaId        Int?
  trainingAreaOther     String?                 @map("training_area_other")
  thematicAreaId        Int
  thematicAreaOther     String?                 @map("thematic_area_other")
  coordinatorId         Int
  fundingSourceId       Int?
  fundingSourceOther    String?                 @map("funding_source_other")
  titleOfTraining       String                  @map("title_of_training")
  startDate             DateTime                @map("start_date")
  endDate               DateTime                @map("end_date")
  venue                 String                  @map("venue")
  fundingAgencyName     String?                 @map("funding_agency_name")
  campusType            CampusType              @map("campus_type")
  generalM              Int                     @map("general_m")
  generalF              Int                     @map("general_f")
  obcM                  Int                     @map("obc_m")
  obcF                  Int                     @map("obc_f")
  scM                   Int                     @map("sc_m")
  scF                   Int                     @map("sc_f")
  stM                   Int                     @map("st_m")
  stF                   Int                     @map("st_f")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  clientele             ClienteleMaster?        @relation(fields: [clienteleId], references: [clienteleId], onDelete: SetNull)
  coordinator           CourseCoordinatorMaster @relation(fields: [coordinatorId], references: [coordinatorId])
  fundingSource         FundingSourceMaster?    @relation(fields: [fundingSourceId], references: [fundingSourceId])
  kvk                   Kvk                     @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  trainingArea          TrainingArea?           @relation(fields: [trainingAreaId], references: [trainingAreaId], onDelete: SetNull)
  trainingThematicArea  TrainingThematicArea    @relation(fields: [thematicAreaId], references: [trainingThematicAreaId], onDelete: Restrict)
  trainingType          TrainingType?           @relation(fields: [trainingTypeId], references: [trainingTypeId], onDelete: SetNull)

  @@index([kvkId])
  @@index([kvkId, startDate])
  @@map("training_achievement")
}

enum CampusType {
  ON_CAMPUS
  OFF_CAMPUS
}
