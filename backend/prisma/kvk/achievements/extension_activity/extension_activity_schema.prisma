model KvkExtensionActivity {
  extensionActivityId Int                 @id @default(autoincrement()) @map("kvk_extension_activity_id")
  kvkId               Int
  fldId               Int?
  staffId             Int?
  activityId          Int?
  numberOfActivities  Int                 @map("number_of_activities")
  startDate           DateTime            @map("start_date")
  endDate             DateTime            @map("end_date")
  farmersGeneralM     Int                 @map("farmers_general_m")
  farmersGeneralF     Int                 @map("farmers_general_f")
  farmersObcM         Int                 @map("farmers_obc_m")
  farmersObcF         Int                 @map("farmers_obc_f")
  farmersScM          Int                 @map("farmers_sc_m")
  farmersScF          Int                 @map("farmers_sc_f")
  farmersStM          Int                 @map("farmers_st_m")
  farmersStF          Int                 @map("farmers_st_f")
  officialsGeneralM   Int                 @map("officials_general_m")
  officialsGeneralF   Int                 @map("officials_general_f")
  officialsObcM       Int                 @map("officials_obc_m")
  officialsObcF       Int                 @map("officials_obc_f")
  officialsScM        Int                 @map("officials_sc_m")
  officialsScF        Int                 @map("officials_sc_f")
  officialsStM        Int                 @map("officials_st_m")
  officialsStF        Int                 @map("officials_st_f")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  extensionActivity   ExtensionActivity?  @relation(fields: [activityId], references: [extensionActivityId], map: "ext_act_relation_fkey")
  fld                 KvkFldIntroduction? @relation(fields: [fldId], references: [kvkFldId], onDelete: Cascade)
  kvk                 Kvk                 @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  staff               KvkStaff?           @relation(fields: [staffId], references: [kvkStaffId])
  fldActivity         FldActivity?        @relation(fields: [activityId], references: [activityId], map: "fld_act_relation_fkey")

  @@index([kvkId])
  @@index([fldId])
  @@index([staffId])
  @@index([activityId])
  @@map("kvk_extension_activity")
}
