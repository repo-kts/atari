model KvkOtherExtensionActivity {
  otherExtensionActivityId Int                         @id @default(autoincrement()) @map("kvk_other_extension_activity_id")
  kvkId                    Int
  fldId                    Int?
  staffId                  Int?
  activityTypeId           Int?
  numberOfActivities       Int                         @map("number_of_activities")
  startDate                DateTime                    @map("start_date")
  endDate                  DateTime                    @map("end_date")
  createdAt                DateTime                    @default(now()) @map("created_at")
  updatedAt                DateTime                    @updatedAt @map("updated_at")
  otherExtensionActivity   OtherExtensionActivity?     @relation(fields: [activityTypeId], references: [otherExtensionActivityId])
  fld                      KvkFldIntroduction?         @relation(fields: [fldId], references: [kvkFldId], onDelete: Cascade)
  kvk                      Kvk                         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  staff                    KvkStaff?                   @relation(fields: [staffId], references: [kvkStaffId])

  @@index([kvkId])
  @@index([fldId])
  @@index([staffId])
  @@index([activityTypeId])
  @@map("kvk_other_extension_activity")
}
