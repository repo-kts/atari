model FldTechnicalFeedback {
  feedbackId Int @id @default(autoincrement()) @map("feedback_id")

  reportingYear Int @map("reporting_year")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  fldId Int
  fld   KvkFldIntroduction @relation(fields: [fldId], references: [kvkFldId], onDelete: Cascade)

  cropId Int
  crop   FldCrop @relation(fields: [cropId], references: [cropId])

  feedback String @map("feedback")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([kvkId])
  @@index([fldId])
  @@index([cropId])
  @@index([reportingYear])
  @@map("fld_technical_feedback")
}
