model FldExtension {
  extensionId        Int                @id @default(autoincrement()) @map("extension_id")
  kvkId              Int
  fldId              Int
  activityId         Int
  activityDate       DateTime           @map("activity_date")
  numberOfActivities Int                @map("number_of_activities")
  remarks            String?            @map("remarks")
  generalM           Int                @map("general_m")
  generalF           Int                @map("general_f")
  obcM               Int                @map("obc_m")
  obcF               Int                @map("obc_f")
  scM                Int                @map("sc_m")
  scF                Int                @map("sc_f")
  stM                Int                @map("st_m")
  stF                Int                @map("st_f")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  reportingYear DateTime? @map("reporting_year")
fldActivity        FldActivity        @relation(fields: [activityId], references: [activityId])
  fld                KvkFldIntroduction @relation(fields: [fldId], references: [kvkFldId], onDelete: Cascade)
  kvk                Kvk                @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([fldId])
  @@index([activityId])
  @@index([reportingYear])
  @@map("fld_extension")
}
