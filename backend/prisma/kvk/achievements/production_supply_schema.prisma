model KvkProductionSupply {
  productionSupplyId String           @id @default(uuid()) @map("production_supply_id")
  kvkId              Int
  reportingYear DateTime? @map("reporting_year")
productCategoryId  Int?             @map("product_category_id")
  productCategoryOther String?        @map("product_category_other")
  productTypeId      Int?             @map("product_type_id")
  productTypeOther   String?          @map("product_type_other")
  productId          Int?             @map("product_id")
  productOther       String?          @map("product_other")
  speciesName        String           @map("species_name")
  // Unit is no longer stored here — it derives from the linked Product's master
  // unit (Product.unit). Edit the product's unit to change it everywhere.
  quantity           Float
  // Used when the product's quantity data type is string/boolean (e.g. "N/A");
  // numeric types continue to use `quantity`.
  quantityText       String?          @map("quantity_text")
  value              Float            @map("value_rs")
  farmersGeneralM    Int              @map("farmers_general_m")
  farmersGeneralF    Int              @map("farmers_general_f")
  farmersObcM        Int              @map("farmers_obc_m")
  farmersObcF        Int              @map("farmers_obc_f")
  farmersScM         Int              @map("farmers_sc_m")
  farmersScF         Int              @map("farmers_sc_f")
  farmersStM         Int              @map("farmers_st_m")
  farmersStF         Int              @map("farmers_st_f")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  kvk                Kvk              @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
productCategory    ProductCategory? @relation(fields: [productCategoryId], references: [productCategoryId], onDelete: SetNull)
  productType        ProductType?     @relation(fields: [productTypeId], references: [productTypeId], onDelete: SetNull)
  product            Product?         @relation(fields: [productId], references: [productId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYear])
  @@index([productCategoryId])
  @@index([productTypeId])
  @@index([productId])
  @@map("kvk_production_supply")
}
