model NicraDignitariesVisited {
  nicraDignitariesVisitedId Int @id @default(autoincrement()) @map("nicra_dignitaries_visited_id")
  kvkId                     Int @map("kvk_id")
  kvk                       Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  dateOfVisit      DateTime @map("date_of_visit")
  dignitaryTypeId  Int?     @map("dignitary_type_id")
  dignitaryType    NicraDignitaryTypeMaster? @relation(fields: [dignitaryTypeId], references: [nicraDignitaryTypeId], onDelete: SetNull, onUpdate: Cascade)
  name             String   @map("name")
  remark           String   @map("remark")
  photographs      String?  @map("photographs")

  @@index([kvkId])
  @@index([dignitaryTypeId])
  @@map("nicra_dignitaries_visited")
}

model NicraDignitaryTypeMaster {
  nicraDignitaryTypeId Int    @id @default(autoincrement()) @map("nicra_dignitary_type_id")
  name                 String @unique @map("name")

  nicraDignitariesVisited NicraDignitariesVisited[]

  @@map("nicra_dignitary_type_master")
}
