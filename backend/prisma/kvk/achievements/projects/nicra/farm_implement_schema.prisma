model NicraFarmImplement {
  nicraFarmImplementId  Int       @id @default(autoincrement()) @map("nicra_farm_implement_id")
  kvkId                 Int       @map("kvk_id")
  kvk                   Kvk       @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  
  reportingYearId       Int?      @map("reporting_year_id")
  reportingYear         YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  startDate             DateTime  @map("start_date")
  endDate               DateTime  @map("end_date")
  nameOfFarmImplement   String    @map("name_of_farm_implement")
  areaCovered           Float     @map("area_covered")
  farmImplementUsedHours Float    @map("farm_implement_used_hours")
  revenueGeneratedRs    Float     @map("revenue_generated_rs")
  expenditureIncurredRepairingRs Float @map("expenditure_incurred_repairing_rs")

  generalM              Int       @default(0) @map("general_m")
  generalF              Int       @default(0) @map("general_f")
  obcM                  Int       @default(0) @map("obc_m")
  obcF                  Int       @default(0) @map("obc_f")
  scM                   Int       @default(0) @map("sc_m")
  scF                   Int       @default(0) @map("sc_f")
  stM                   Int       @default(0) @map("st_m")
  stF                   Int       @default(0) @map("st_f")

  photographs           String   @map("photographs")

  @@index([kvkId])
  @@map("nicra_farm_implement")
}
