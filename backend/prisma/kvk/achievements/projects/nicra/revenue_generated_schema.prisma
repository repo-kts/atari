model NicraRevenueGenerated {
  nicraRevenueGeneratedId Int @id @default(autoincrement()) @map("nicra_revenue_generated_id")
  kvkId                   Int @map("kvk_id")
  kvk                     Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  reportingYear DateTime? @map("reporting_year")

  revenue Float @map("revenue")

  @@index([kvkId])
  @@map("nicra_revenue_generated")
}
