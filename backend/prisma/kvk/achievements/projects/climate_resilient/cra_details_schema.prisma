model CraDetails {
  craDetailsId Int @id @default(autoincrement()) @map("cra_details_id")
  kvkId        Int @map("kvk_id")
  kvk          Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  reportingYear DateTime? @map("reporting_year")

  seasonId Int?    @map("season_id")
  season   Season? @relation(fields: [seasonId], references: [seasonId], onDelete: SetNull)

  interventions String @map("technology_demonstrated")

  croppingSystem String @map("croping_system")

  croppingSystemId Int?             @map("cra_croping_system_id")
  croppingSystemRef CraCropingSystem? @relation(fields: [croppingSystemId], references: [craCropingSystemId], onDelete: SetNull)

  farmingSystemId Int?            @map("cra_farming_system_id")
  farmingSystem   CraFarmingSystem? @relation(fields: [farmingSystemId], references: [craFarmingSystemId], onDelete: SetNull)

  areaInAcre Float @map("area_under_demonstration_acre")

  // Farmers Details
  generalM Int @default(0) @map("general_m")
  generalF Int @default(0) @map("general_f")
  obcM     Int @default(0) @map("obc_m")
  obcF     Int @default(0) @map("obc_f")
  scM      Int @default(0) @map("sc_m")
  scF      Int @default(0) @map("sc_f")
  stM      Int @default(0) @map("st_m")
  stF      Int @default(0) @map("st_f")

  cropYield Float @map("crop_yield_qha")
  systemProductivity Float @map("system_productivity_qha")
  totalReturn Float @map("total_return_rsha")
  farmerPracticeYield Float @map("yield_obtained_under_farmer_practices_qha")

  @@index([kvkId])
  @@index([croppingSystemId])
  @@index([farmingSystemId])
  @@map("cra_details")
}
