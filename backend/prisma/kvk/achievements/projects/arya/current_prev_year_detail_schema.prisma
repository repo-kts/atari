model AryaPrevYear {
  aryaPrevYearId              Int         @id @default(autoincrement()) @map("arya_prev_year_id")
  kvkId                       Int
  enterpriseId                Int
  unitsMale                   Int         @map("units_male")
  unitsFemale                 Int         @map("units_female")
  nonFunctionalUnitsClosed    Int         @map("non_functional_units_closed")
  dateOfClosing               DateTime?   @map("date_of_closing")
  nonFunctionalUnitsRestarted Int         @map("non_functional_units_restarted")
  dateOfRestart               DateTime?   @map("date_of_restart")
  numberOfUnits               Int         @map("number_of_units")
  unitCapacity                Float       @map("unit_capacity")
  fixedCost                   Float       @map("fixed_cost")
  variableCost                Float       @map("variable_cost")
  totalProductionPerUnitYear  Float       @map("total_production_per_unit_year")
  grossCostPerUnitYear        Float       @map("gross_cost_per_unit_year")
  grossReturnPerUnitYear      Float       @map("gross_return_per_unit_year")
  netBenefitPerUnitYear       Float       @map("net_benefit_per_unit_year")
  employmentFamilyMandays     Float       @map("employment_family_mandays")
  employmentOtherMandays      Float       @map("employment_other_mandays")
  personsVisitedUnit          Int         @map("persons_visited_unit")
  createdAt                   DateTime    @default(now()) @map("created_at")
  updatedAt                   DateTime    @updatedAt @map("updated_at")
  reportingYear DateTime? @map("reporting_year")
enterprise                  Enterprise  @relation(fields: [enterpriseId], references: [enterpriseId])
  kvk                         Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([enterpriseId])
  @@index([reportingYear])
  @@map("arya_prev_year")
}
