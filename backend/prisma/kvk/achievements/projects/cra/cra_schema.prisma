generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CraDetails {
  craDetailsId      Int      @id @default(autoincrement()) @map("cra_details_id")
  kvkId             Int      @map("kvk_id")
  reportingYearId   Int      @map("reporting_year_id")
  seasonId          Int      @map("season_id")
  interventions     String   @map("interventions") @db.Text
  croppingSystem    String   @map("cropping_system") @db.Text
  farmingSystemId   Int      @map("farming_system_id")
  areaInAcre        Decimal  @map("area_in_acre") @db.Decimal(10, 2)
  
  // Farmers Details
  genM              Int      @default(0) @map("gen_m")
  genF              Int      @default(0) @map("gen_f")
  obcM              Int      @default(0) @map("obc_m")
  obcF              Int      @default(0) @map("obc_f")
  scM               Int      @default(0) @map("sc_m")
  scF               Int      @default(0) @map("sc_f")
  stM               Int      @default(0) @map("st_m")
  stF               Int      @default(0) @map("st_f")
  
  cropYield           Decimal  @default(0) @map("crop_yield") @db.Decimal(10, 2)
  systemProductivity  Decimal  @default(0) @map("system_productivity") @db.Decimal(10, 2)
  totalReturn         Decimal  @default(0) @map("total_return") @db.Decimal(10, 2)
  farmerPracticeYield Decimal  @default(0) @map("farmer_practice_yield") @db.Decimal(10, 2)

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  kvk               Kvk      @relation(fields: [kvkId], references: [kvkId])

  @@map("cra_details")
}

model CraExtensionActivity {
  craExtensionActivityId Int      @id @default(autoincrement()) @map("cra_extension_activity_id")
  kvkId                  Int      @map("kvk_id")
  extensionActivityId    Int      @map("extension_activity_id")
  startDate              DateTime @map("start_date")
  endDate                DateTime @map("end_date")
  
  // Farmers Details
  genM                   Int      @default(0) @map("gen_m")
  genF                   Int      @default(0) @map("gen_f")
  obcM                   Int      @default(0) @map("obc_m")
  obcF                   Int      @default(0) @map("obc_f")
  scM                    Int      @default(0) @map("sc_m")
  scF                    Int      @default(0) @map("sc_f")
  stM                    Int      @default(0) @map("st_m")
  stF                    Int      @default(0) @map("st_f")
  
  exposureVisit          Int      @default(0) @map("exposure_visit")

  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  kvk                    Kvk      @relation(fields: [kvkId], references: [kvkId])
  extensionActivity      FldActivity @relation(fields: [extensionActivityId], references: [activityId])

  @@map("cra_extension_activity")
}
