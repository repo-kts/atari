model DrmrDetails {
  drmrDetailsId            Int         @id @default(autoincrement()) @map("drmr_details_id")
  kvkId                    Int
  situation                String      @map("situation")
  varietyImprovedPractice  String      @map("variety_improved_practice")
  varietyFarmerPractice    String      @map("variety_farmer_practice")
  yieldImprovedKgPerHa     Float       @map("yield_improved_kg_per_ha")
  yieldFarmerKgPerHa       Float       @map("yield_farmer_kg_per_ha")
  yieldIncreasePercent     Float       @map("yield_increase_percent")
  costImprovedPerHa        Float       @map("cost_improved_per_ha")
  costFarmerPerHa          Float       @map("cost_farmer_per_ha")
  grossReturnImprovedPerHa Float       @map("gross_return_improved_per_ha")
  grossReturnFarmerPerHa   Float       @map("gross_return_farmer_per_ha")
  netReturnImprovedPerHa   Float       @map("net_return_improved_per_ha")
  netReturnFarmerPerHa     Float       @map("net_return_farmer_per_ha")
  bcRatioImproved          Float       @map("bc_ratio_improved")
  bcRatioFarmer            Float       @map("bc_ratio_farmer")
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @updatedAt @map("updated_at")
  reportingYearId          Int?        @map("reporting_year_id")
  kvk                      Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear            YearMaster? @relation(fields: [reportingYearId], references: [yearId])

  @@index([kvkId])
  @@index([reportingYearId])
  @@map("drmr_details")
}
