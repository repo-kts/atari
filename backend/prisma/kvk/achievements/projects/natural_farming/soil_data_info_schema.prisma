model SoilDataInformation {
  soilDataInformationId Int               @id @default(autoincrement()) @map("soil_data_information_id")
  kvkId                 Int
  year                  Int
  reportingYearDate     DateTime?         @map("reporting_year_date")
  crop                  String
  seasonId              Int?
  soilParameterId       Int?              @map("soil_parameter_id")
  phBefore              Float             @map("ph_before")
  ecBefore              Float             @map("ec_before")
  ocBefore              Float             @map("oc_before")
  nBefore               Float             @map("n_before")
  pBefore               Float             @map("p_before")
  kBefore               Float             @map("k_before")
  soilMicrobesBefore    Float             @map("soil_microbes_before")
  phAfter               Float             @map("ph_after")
  ecAfter               Float             @map("ec_after")
  ocAfter               Float             @map("oc_after")
  nAfter                Float             @map("n_after")
  pAfter                Float             @map("p_after")
  kAfter                Float             @map("k_after")
  soilMicrobesAfter     Float             @map("soil_microbes_after")
  kvk                   Kvk               @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  season                Season?           @relation(fields: [seasonId], references: [seasonId])
  soilParameterMaster   NaturalFarmingSoilParameterMaster? @relation(fields: [soilParameterId], references: [naturalFarmingSoilParameterId], onDelete: SetNull, onUpdate: Cascade)

  @@index([kvkId])
  @@index([reportingYearDate])
  @@index([kvkId, reportingYearDate])
  @@map("soil_data_information")
}

model NaturalFarmingSoilParameterMaster {
  naturalFarmingSoilParameterId Int                   @id @default(autoincrement()) @map("natural_farming_soil_parameter_id")
  parameterName                 String                @unique @map("parameter_name")
  soilDataInformations          SoilDataInformation[]

  @@map("natural_farming_soil_parameter_master")
}
