model GeographicalInfo {
  geographicalInfoId Int         @id @default(autoincrement()) @map("geographical_info_id")
  kvkId              Int
  startDate          DateTime    @map("start_date")
  endDate            DateTime    @map("end_date")
  agroClimaticZone   String      @map("agro_climatic_zone")
  farmingSituation   String      @map("farming_situation")
  latitude           Float       @map("latitude")
  longitude          Float       @map("longitude")
  reportingYear DateTime? @map("reporting_year")
kvk                Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@map("geographical_info")
}
