model NariBioFortifiedCrop {
  nariBioFortifiedCropId Int @id @default(autoincrement()) @map("nari_bio_fortified_crop_id")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  reportingYear DateTime? @map("reporting_year")

  seasonId Int    @map("season_id")
  season   Season @relation(fields: [seasonId], references: [seasonId])

  activityId Int          @map("activity_id")
  activity   NariActivity @relation(fields: [activityId], references: [nariActivityId])

  nameOfNutriSmartVillage String @map("name_of_nutri_smart_village")

  cropCategoryId Int          @map("crop_category_id")
  cropCategory   CropCategory @relation(fields: [cropCategoryId], references: [cropCategoryId])

  nameOfCrop String @map("name_of_crop")
  variety    String @map("variety")
  areaHa     Float  @map("area_ha")

  generalM Int @default(0) @map("general_m")
  generalF Int @default(0) @map("general_f")
  obcM     Int @default(0) @map("obc_m")
  obcF     Int @default(0) @map("obc_f")
  scM      Int @default(0) @map("sc_m")
  scF      Int @default(0) @map("sc_f")
  stM      Int @default(0) @map("st_m")
  stF      Int @default(0) @map("st_f")

  status String @default("ONGOING") @map("status")
  results NariBioFortifiedCropResult[]

  @@index([kvkId])
  @@index([activityId])
  @@map("nari_bio_fortified_crop")
}

model CropCategory {
  cropCategoryId Int    @id @default(autoincrement()) @map("crop_category_id")
  name           String @unique @map("name")

  nariBioFortifiedCrops NariBioFortifiedCrop[]

  @@map("crop_category")
}

model NariBioFortifiedCropResult {
  nariBioFortifiedCropResultId Int @id @default(autoincrement()) @map("nari_bio_fortified_crop_result_id")

  nariBioFortifiedCropId Int @map("nari_bio_fortified_crop_id")
  nariBioFortifiedCrop   NariBioFortifiedCrop @relation(fields: [nariBioFortifiedCropId], references: [nariBioFortifiedCropId], onDelete: Cascade)

  reportingYear DateTime? @map("reporting_year")
  cropName      String    @map("name_of_crops")
  variety       String    @map("varieties")
  areaHa        Float     @map("area_grown_ha")
  productionKg  Float     @map("production_kg")
  consumptionGm Float     @map("consumption_gm_day_person")
  formOfConsumption String @map("form_of_consumption")
  daysInYear    Int       @map("no_of_days_in_year")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([nariBioFortifiedCropId])
  @@map("nari_bio_fortified_crop_result")
}
