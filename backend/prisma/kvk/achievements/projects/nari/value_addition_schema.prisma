model NariValueAddition {
  nariValueAdditionId Int @id @default(autoincrement()) @map("nari_value_addition_id")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  reportingYear DateTime? @map("reporting_year")

  activityId Int          @map("activity_id")
  activity   NariActivity @relation(fields: [activityId], references: [nariActivityId])

  nameOfNutriSmartVillage String @map("name_of_nutri_smart_village")
  nameOfCrop              String @map("name_of_crop")
  nameOfValueAddedProduct String @map("name_of_value_added_product")

  generalM Int @default(0) @map("general_m")
  generalF Int @default(0) @map("general_f")
  obcM     Int @default(0) @map("obc_m")
  obcF     Int @default(0) @map("obc_f")
  scM      Int @default(0) @map("sc_m")
  scF      Int @default(0) @map("sc_f")
  stM      Int @default(0) @map("st_m")
  stF      Int @default(0) @map("st_f")

  status NariStatus @default(ONGOING) @map("status")
  results NariValueAdditionResult[]

  @@index([kvkId])
  @@index([activityId])
  @@map("nari_value_addition")
}

model NariValueAdditionResult {
  nariValueAdditionResultId Int @id @default(autoincrement()) @map("nari_value_addition_result_id")

  nariValueAdditionId Int @map("nari_value_addition_id")
  nariValueAddition   NariValueAddition @relation(fields: [nariValueAdditionId], references: [nariValueAdditionId], onDelete: Cascade)

  reportingYear  DateTime? @map("reporting_year")
  productName    String    @map("name_of_product")
  amountProduced Float     @map("amount_produced_kg")
  marketPrice    Float     @map("market_price_rs_kg")
  netIncome      Float     @map("net_income_rs")
  shelfLife      String    @map("shelf_life")
  fssaiCertified String    @map("fssai_certification")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([nariValueAdditionId])
  @@map("nari_value_addition_result")
}
