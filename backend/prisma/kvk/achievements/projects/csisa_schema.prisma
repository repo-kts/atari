model Csisa {
  csisaId          Int               @id @default(autoincrement()) @map("csisa_id")
  kvkId            Int
  seasonId         Int?
  villagesCovered  Int               @map("villages_covered")
  blocksCovered    Int               @map("blocks_covered")
  districtsCovered Int               @map("districts_covered")
  respondents      Int               @map("respondents")
  trialName        String            @map("trial_name")
  areaCoveredHa    Float             @map("area_covered_ha")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  reportingYearId  Int?              @map("reporting_year_id")
  kvk              Kvk               @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear    YearMaster?       @relation(fields: [reportingYearId], references: [yearId])
  season           Season?           @relation(fields: [seasonId], references: [seasonId])
  cropDetails      CsisaCropDetail[]

  @@index([kvkId])
  @@index([seasonId])
  @@index([reportingYearId])
  @@map("csisa")
}

model CsisaCropDetail {
  csisaCropDetailId Int      @id @default(autoincrement()) @map("csisa_crop_detail_id")
  csisaId           Int
  cropName          String   @map("crop_name")
  technologyOption  String   @map("technology_option")
  varietyName       String   @map("variety_name")
  durationDays      Int      @map("duration_days")
  sowingDate        DateTime @map("sowing_date")
  harvestingDate    DateTime @map("harvesting_date")
  daysOfMaturity    Int      @map("days_of_maturity")
  grainYieldQPerHa  Float    @map("grain_yield_q_per_ha")
  costOfCultivation Float    @map("cost_of_cultivation_per_ha")
  grossReturn       Float    @map("gross_return_per_ha")
  netReturn         Float    @map("net_return_per_ha")
  bcr               Float    @map("bcr")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  csisa             Csisa    @relation(fields: [csisaId], references: [csisaId], onDelete: Cascade)

  @@index([csisaId])
  @@map("csisa_crop_detail")
}
