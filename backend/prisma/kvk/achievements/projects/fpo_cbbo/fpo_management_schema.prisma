model FpoManagement {
  fpoManagementId       Int         @id @default(autoincrement()) @map("fpo_management_id")
  kvkId                 Int
  fpoName               String      @map("fpo_name")
  address               String      @map("address")
  registrationNumber    String      @unique @map("registration_number")
  registrationDate      DateTime    @map("registration_date")
  proposedActivity      String      @map("proposed_activity")
  commodityIdentified   String      @map("commodity_identified")
  totalBomMembers       Int         @map("total_bom_members")
  totalFarmersAttached  Int         @map("total_farmers_attached")
  financialPositionLakh Float       @map("financial_position_lakh")
  successIndicator      String      @map("success_indicator")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  reportingYearId       Int?        @map("reporting_year_id")
  kvk                   Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear         YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([fpoName])
  @@index([reportingYearId])
  @@map("fpo_management")
}
