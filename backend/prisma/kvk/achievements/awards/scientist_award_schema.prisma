model ScientistAward {
  scientistAwardId    String      @id @default(uuid()) @map("scientist_award_id")
  kvkId               Int
  reportingYear DateTime? @map("reporting_year")
scientistName       String      @map("scientist_name")
  awardName           String      @map("award_name")
  amount              Int         @map("amount")
  achievement         String      @map("achievement")
  conferringAuthority String      @map("conferring_authority")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  kvk                 Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@index([createdAt])
  @@map("scientist_award")
}
