model FarmerAward {
  farmerAwardID Int @id @default(autoincrement()) @map("farmer_award_id")

  kvkId Int
  kvk   Kvk @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  farmerName String @map("farmer_name")
  contactNumber String @map("contact_number")
  address String @map("address")
  awardName String @map("award_name")
  amount Int @map("amount")
  achievement   String @map("achievement")
  conferringAuthority String @map("conferring_authority")
  reportingYear Int? @map("reporting_year")
  image String? @map("image")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  

  @@index([kvkId])
  @@map("farmer_award")
}
