model KkvWorldSoilCelebration {
  worldSoilCelebrationId    Int         @id @default(autoincrement()) @map("world_soil_celebration_id")
  kvkId                     Int
  activitiesConducted       Int         @map("activities_conducted")
  soilHealthCardDistributed Int         @map("soil_health_card_distributed")
  vipNames                  String      @map("vip_names")
  participants              Int         @map("participants")
  generalM                  Int         @map("general_m")
  generalF                  Int         @map("general_f")
  obcM                      Int         @map("obc_m")
  obcF                      Int         @map("obc_f")
  scM                       Int         @map("sc_m")
  scF                       Int         @map("sc_f")
  stM                       Int         @map("st_m")
  stF                       Int         @map("st_f")
  createdAt                 DateTime    @default(now()) @map("created_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")
  reportingYear DateTime? @map("reporting_year")
kvk                       Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@map("kvk_world_soil_celebration")
}
