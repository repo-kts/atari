model SwachhtaPakhwada {
  swachhtaPakhwadaId Int      @id @default(autoincrement()) @map("swachhta_pakhwada_id")
  kvkId              Int
  observationDate    DateTime @map("observation_date")
  totalActivities    Int      @map("total_activities")
  staffCount         Int      @map("staff_count")
  farmerCount        Int      @map("farmer_count")
  othersCount        Int      @map("others_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  kvk                Kvk      @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  @@index([kvkId])
  @@map("swachhta_pakhwada")
}
