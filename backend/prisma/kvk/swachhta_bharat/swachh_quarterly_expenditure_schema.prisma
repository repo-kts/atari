model SwachhQuarterlyExpenditure {
  swachhQuarterlyExpenditureId Int         @id @default(autoincrement()) @map("swachh_quarterly_expenditure_id")
  kvkId                        Int
  vermiVillageCovered          Int         @map("vermi_village_covered")
  vermiTotalExpenditure        Float       @map("vermi_total_expenditure")
  otherVillageCovered          Int         @map("other_village_covered")
  otherTotalExpenditure        Float       @map("other_total_expenditure")
  createdAt                    DateTime    @default(now()) @map("created_at")
  updatedAt                    DateTime    @updatedAt @map("updated_at")
  reportingYear DateTime? @map("reporting_year")
kvk                          Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@map("swachh_quarterly_expenditure")
}
