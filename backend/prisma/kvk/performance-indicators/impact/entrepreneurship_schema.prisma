model Entrepreneurship {
  entrepreneurshipId      String      @id @default(uuid()) @map("entrepreneurship_id")
  kvkId                   Int
  reportingYearId         Int?        @map("reporting_year_id")
  entrepreneurName        String      @map("entrepreneur_name")
  registeredAddress       String      @map("registered_address")
  yearOfEstablishment     Int         @map("year_of_establishment")
  enterpriseType          String      @map("enterprise_type")
  membersAssociated       Int         @map("members_associated")
  registrationDetails     String      @map("registration_details")
  technicalComponents     String      @map("technical_components")
  kvkRole                 String      @map("kvk_role")
  annualIncome            Float       @map("annual_income")
  developmentTimeline     String      @map("development_timeline")
  statusBeforeAfter       String      @map("status_before_after")
  presentWorkingCondition String      @map("present_working_condition")
  majorAchievements       String      @map("major_achievements")
  majorConstraints        String      @map("major_constraints")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  kvk                     Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear           YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@index([enterpriseType])
  @@index([createdAt])
  @@map("entrepreneurship")
}
