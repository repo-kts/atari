model SuccessStory {
  successStoryId         String      @id @default(uuid()) @map("success_story_id")
  kvkId                  Int
  reportingYearId        Int?        @map("reporting_year_id")
  farmerName             String      @map("farmer_name")
  dateOfBirth            DateTime?   @map("date_of_birth")
  education              String      @map("education")
  experience             String      @map("experience")
  contact                String      @map("contact")
  fullAddress            String      @map("full_address")
  professionalMembership String?     @map("professional_membership")
  awardsReceived         String?     @map("awards_received")
  majorAchievement       String      @map("major_achievement")
  storyTitle             String      @map("story_title")
  problemStatement       String      @map("problem_statement")
  kvkIntervention        String      @map("kvk_intervention")
  practicesFollowed      String      @map("practices_followed")
  results                String      @map("results")
  impact                 String      @map("impact")
  futurePlans            String?     @map("future_plans")
  supportingImages       String?     @map("supporting_images")
  enterprise             String      @map("enterprise")
  grossIncome            Float       @map("gross_income")
  netIncome              Float       @map("net_income")
  costBenefitRatio       Float       @map("cost_benefit_ratio")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  kvk                    Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear          YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@index([farmerName])
  @@index([createdAt])
  @@map("success_story")
}
