model InstructionalFarmLivestock {
  instructionalFarmLivestockId String      @id @default(uuid()) @map("instructional_farm_livestock_id")
  kvkId                        Int
  reportingYearId              Int?        @map("reporting_year_id")
  animalName                   String      @map("animal_name")
  speciesBreed                 String      @map("species_breed")
  typeOfProduce                String      @map("type_of_produce")
  quantity                     Float       @map("quantity")
  costOfInputs                 Float       @map("cost_of_inputs")
  grossIncome                  Float       @map("gross_income")
  remarks                      String      @map("remarks")
  createdAt                    DateTime    @default(now()) @map("created_at")
  updatedAt                    DateTime    @updatedAt @map("updated_at")
  kvk                          Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear                YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@index([animalName])
  @@index([createdAt])
  @@map("instructional_farm_livestock")
}
