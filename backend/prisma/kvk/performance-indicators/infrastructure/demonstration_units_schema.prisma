model DemonstrationUnit {
  demonstrationUnitId String      @id @default(uuid()) @map("demonstration_unit_id")
  kvkId               Int
  reportingYearId     Int?        @map("reporting_year_id")
  demoUnitName        String      @map("demo_unit_name")
  yearOfEstablishment Int         @map("year_of_establishment")
  area                Float       @map("area")
  varietyBreed        String      @map("variety_breed")
  produce             String      @map("produce")
  quantity            Float       @map("quantity")
  costOfInputs        Float       @map("cost_of_inputs")
  grossIncome         Float       @map("gross_income")
  remarks             String      @map("remarks")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  kvk                 Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear       YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@index([demoUnitName])
  @@index([createdAt])
  @@map("demonstration_unit")
}
