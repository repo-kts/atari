model ProductionUnit {
  productionUnitId String      @id @default(uuid()) @map("production_unit_id")
  kvkId            Int
  reportingYear DateTime? @map("reporting_year")
productName      String      @map("product_name")
  quantity         Float       @map("quantity")
  costOfInputs     Float       @map("cost_of_inputs")
  grossIncome      Float       @map("gross_income")
  remarks          String      @map("remarks")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  kvk              Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@index([productName])
  @@index([createdAt])
  @@map("production_unit")
}
