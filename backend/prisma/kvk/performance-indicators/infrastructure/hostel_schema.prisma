model HostelUtilization {
  hostelUtilizationId String      @id @default(uuid()) @map("hostel_utilization_id")
  kvkId               Int
  reportingYearId     Int?        @map("reporting_year_id")
  months              String      @map("months")
  traineesStayed      Int         @map("trainees_stayed")
  traineeDays         Int         @map("trainee_days")
  reasonForShortFall  String      @map("reason_for_short_fall")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  kvk                 Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
  reportingYear       YearMaster? @relation(fields: [reportingYearId], references: [yearId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYearId])
  @@index([months])
  @@index([createdAt])
  @@map("hostel_utilization")
}
