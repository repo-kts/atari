model InstructionalFarmCrop {
  instructionalFarmCropId String      @id @default(uuid()) @map("instructional_farm_crop_id")
  kvkId                   Int
  reportingYear DateTime? @map("reporting_year")
seasonId                Int?        @map("season_id")
  cropName                String      @map("crop_name")
  area                    Float       @map("area")
  variety                 String      @map("variety")
  typeOfProduce           String      @map("type_of_produce")
  quantity                Float       @map("quantity")
  costOfInputs            Float       @map("cost_of_inputs")
  grossIncome             Float       @map("gross_income")
  remarks                 String      @map("remarks")
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  kvk                     Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
season                  Season?     @relation(fields: [seasonId], references: [seasonId], onDelete: SetNull)

  @@index([kvkId])
  @@index([reportingYear])
  @@index([seasonId])
  @@index([cropName])
  @@index([createdAt])
  @@map("instructional_farm_crop")
}
