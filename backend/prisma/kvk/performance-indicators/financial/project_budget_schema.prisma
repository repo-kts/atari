model ProjectBudget {
  projectBudgetId    String           @id @default(uuid()) @map("project_budget_id")
  kvkId              Int              
  startDate          DateTime         @map("start_date")
  endDate            DateTime         @map("end_date")
  financialProjectId Int              @map("financial_project_id")
  projectName        FinancialProject @relation(fields: [financialProjectId], references: [financialProjectId], onDelete: Cascade)
  accountNumber      String           @map("account_number")
  sourceOfFundingId  Int?             @map("source_of_funding_id")
  sourceOfFunding    FundingSourceMaster? @relation(fields: [sourceOfFundingId], references: [fundingSourceId], onDelete: SetNull)
  specifyProjectName String?          @map("specify_project_name")
  specifyAgencyName  String?          @map("specify_agency_name")
  fundingAgencyName  String?          @map("funding_agency_name")
  budgetEstimate     Float            @map("budget_estimate")
  budgetAllocated    Float            @map("budget_allocated")
  budgetReleased     Float            @map("budget_released")
  expenditure        Float            @map("expenditure")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  kvk                Kvk              @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  @@index([kvkId])
  @@index([financialProjectId])
  @@index([sourceOfFundingId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("project_budget")
}
