model ProjectBudget {
  projectBudgetId String   @id @default(uuid()) @map("project_budget_id")
  kvkId           Int
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  projectName     String   @map("project_name")
  accountNumber   String   @map("account_number")
  fundingAgency   String?  @map("funding_agency")
  budgetEstimate  Float    @map("budget_estimate")
  budgetAllocated Float    @map("budget_allocated")
  budgetReleased  Float    @map("budget_released")
  expenditure     Float    @map("expenditure")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  kvk             Kvk      @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  @@index([kvkId])
  @@index([projectName])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("project_budget")
}
