model BudgetDetail {
  budgetDetailId                String      @id @default(uuid()) @map("budget_detail_id")
  kvkId                         Int
  startDate                     DateTime    @map("start_date")
  endDate                       DateTime    @map("end_date")
  salaryAllocation              Float       @map("salary_allocation")
  salaryExpenditure             Float       @map("salary_expenditure")
  generalMainGrantAllocation    Float   @map("general_main_grant_allocation")
  generalMainGrantExpenditure   Float   @map("general_main_grant_expenditure")
  generalTspGrantAllocation     Float   @map("general_tsp_grant_allocation")
  generalTspGrantExpenditure    Float   @map("general_tsp_grant_expenditure")
  generalScspGrantAllocation    Float   @map("general_scsp_grant_allocation")
  generalScspGrantExpenditure   Float   @map("general_scsp_grant_expenditure")
  capitalMainGrantAllocation    Float   @map("capital_main_grant_allocation")
  capitalMainGrantExpenditure   Float   @map("capital_main_grant_expenditure")
  capitalTspGrantAllocation     Float   @map("capital_tsp_grant_allocation")
  capitalTspGrantExpenditure    Float   @map("capital_tsp_grant_expenditure")
  capitalScspGrantAllocation    Float   @map("capital_scsp_grant_allocation")
  capitalScspGrantExpenditure   Float   @map("capital_scsp_grant_expenditure")
  createdAt                     DateTime    @default(now()) @map("created_at")
  updatedAt                     DateTime    @updatedAt @map("updated_at")
  kvk                           Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)

  @@index([kvkId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@map("budget_detail")
}
