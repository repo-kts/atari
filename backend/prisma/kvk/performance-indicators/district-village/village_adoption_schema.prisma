model VillageAdoption {
  villageAdoptionId String      @id @default(uuid()) @map("village_adoption_id")
  kvkId             Int
  reportingYear DateTime? @map("reporting_year")
village           String      @map("village")
  block             String      @map("block")
  actionTaken       String      @map("action_taken")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  kvk               Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@index([village])
  @@index([createdAt])
  @@map("village_adoption")
}
