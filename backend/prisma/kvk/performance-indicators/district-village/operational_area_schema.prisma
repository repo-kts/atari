model OperationalArea {
  operationalAreaId String      @id @default(uuid()) @map("operational_area_id")
  kvkId             Int
  reportingYear DateTime? @map("reporting_year")
taluk             String      @map("taluk")
  block             String      @map("block")
  village           String      @map("village")
  majorCrops        String      @map("major_crops")
  majorProblems     String      @map("major_problems")
  thrustAreas       String      @map("thrust_areas")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  kvk               Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@index([village])
  @@index([block])
  @@index([createdAt])
  @@map("operational_area")
}
