model SpecialProgramme {
  specialProgrammeId String      @id @default(uuid()) @map("special_programme_id")
  kvkId              Int
  reportingYear DateTime? @map("reporting_year")
programmeType      String      @map("programme_type")
  programmeName      String      @map("programme_name")
  programmePurpose   String      @map("programme_purpose")
  initiationDate     DateTime    @map("initiation_date")
  fundingAgency      String      @map("funding_agency")
  amount             Float       @map("amount")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  kvk                Kvk         @relation(fields: [kvkId], references: [kvkId], onDelete: Cascade)
@@index([kvkId])
  @@index([reportingYear])
  @@index([programmeType])
  @@index([programmeName])
  @@index([initiationDate])
  @@index([createdAt])
  @@map("special_programme")
}
