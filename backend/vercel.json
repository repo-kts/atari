{
    "version": 2,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.js"
        }
    ],
    "functions": {
        "index.js": {
            "maxDuration": 300
        },
        "api/report-generation.js": {
            "maxDuration": 300,
            "experimentalTriggers": [
                {
                    "type": "queue/v2beta",
                    "topic": "report-generation",
                    "retryAfterSeconds": 30,
                    "initialDelaySeconds": 0
                }
            ]
        }
    },
    "env": {
        "NODE_ENV": "production"
    }
}
